{
    "name":  "kca-landing-page",
    "version":  "0.1.0",
    "private":  true,
    "homepage":  "/",
    "dependencies":  {
                         "@react-three/drei":  "^9.122.0",
                         "@react-three/fiber":  "^8.18.0",
                         "firebase":  "^12.12.1",
                         "framer-motion":  "^12.38.0",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0",
                         "react-icons":  "^5.5.0",
                         "three":  "^0.183.2"
                     },
    "devDependencies":  {
                            "@vitejs/plugin-react":  "^4.2.0",
                            "gh-pages":  "^6.0.0",
                            "googleapis": "^140.0.0",
                            "lighthouse":  "^12.1.0",
                            "react-snap":  "^1.23.0",
                            "vite":  "^5.0.0"
                        },
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build",
                    "postbuild":  "react-snap",
                    "preview":  "vite preview",
                    "predeploy":  "npm run build",
                    "deploy":  "gh-pages -d dist --dotfiles",
                    "postinstall":  "node patch-react-snap.cjs",
                    "audit:lighthouse": "node ../scripts/lighthouse_audit.js",
                    "audit:gsc": "node ../scripts/search_console_audit.js"
                },
    "reactSnap":  {
                      "source":  "dist",
                      "puppeteerArgs":  [
                                            "--no-sandbox",
                                            "--disable-setuid-sandbox"
                                        ]
                  },
    "overrides":  {
                      "react-snap":  {
                                         "puppeteer":  "^22.0.0"
                                     }
                  }
}
